---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath } from '../../../i18n/utils';
import { stripLangSuffix } from '../../../i18n/content';
import { languages, defaultLang, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(languages).map((code) => ({
    params: { lang: code === defaultLang ? undefined : code },
    props: { lang: code as Lang },
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const entries = await getCollection('research', ({ data }) => data.lang === lang);
const sorted = entries.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<MainLayout title={t('page.research.meta')} description={t('page.research.description')} lang={lang}>
  <h2>{t('page.research.title')}</h2>
  <p class="collection-lede">{t('page.research.lede')}</p>
  <ul class="collection-list">
    {sorted.map((entry) => (
      <li class="collection-list__item">
        <a href={getLocalizedPath(lang, `/research/${stripLangSuffix(entry.id)}`)}>
          <span class="collection-list__pillar">{t(`research.status.${entry.data.status}`)}</span>
          <h3 class="collection-list__title">{entry.data.title}</h3>
          <p class="collection-list__summary">{entry.data.summary}</p>
          <p class="collection-list__meta">{entry.data.date}{entry.data.partners ? ` · ${entry.data.partners.join(', ')}` : ''}</p>
        </a>
      </li>
    ))}
  </ul>
</MainLayout>
