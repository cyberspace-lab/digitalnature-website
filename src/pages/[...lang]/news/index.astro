---
import MainLayout from '../../../layouts/MainLayout.astro';
import BlogCard from '../../../components/BlogCard.vue';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath } from '../../../i18n/utils';
import { stripLangSuffix } from '../../../i18n/content';
import { languages, defaultLang, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(languages).map((code) => ({
    params: { lang: code === defaultLang ? undefined : code },
    props: { lang: code as Lang },
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const entries = await getCollection('news', ({ data }) => data.lang === lang);
const sorted = entries.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<MainLayout title={t('page.news.title')} lang={lang}>
  <h2>{t('page.news.title')}</h2>
  <div class="blog-posts">
    {sorted.map((entry, index) => (
      <BlogCard
        client:load
        slug={getLocalizedPath(lang, `/news/${stripLangSuffix(entry.id)}`)}
        featuredImage={entry.data.featuredImage ?? ''}
        title={entry.data.title}
        date={entry.data.date}
        index={index}
      />
    ))}
  </div>
</MainLayout>
