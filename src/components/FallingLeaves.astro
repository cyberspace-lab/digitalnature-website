---
// Decorative cyber-leaf accent — three neon leaves drift diagonally
// across the hero on first paint. Dark/cyber mode + ≥768px only.
// Each leaf carries one of the three brand accents (magenta / green /
// cyan) with a soft glow, evoking digital flora drifting through the
// synthwave dusk. Pure CSS one-shot animation, runs once.
---

<div class="cn-leaves" aria-hidden="true">
  <svg
    class="cn-leaf cn-leaf--1"
    viewBox="0 0 64 96"
    width="44"
    height="66"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M32 4 C50 22 56 50 32 92 C8 50 14 22 32 4 Z" />
    <path d="M32 8 L32 88" />
    <path d="M32 22 L20 32" />
    <path d="M32 22 L44 32" />
    <path d="M32 38 L18 50" />
    <path d="M32 38 L46 50" />
    <path d="M32 56 L20 66" />
    <path d="M32 56 L44 66" />
  </svg>

  <svg
    class="cn-leaf cn-leaf--2"
    viewBox="0 0 80 80"
    width="56"
    height="56"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M40 6 C70 20 76 56 40 76 C4 56 10 20 40 6 Z" />
    <path d="M40 10 L40 72" />
    <path d="M40 24 L22 32" />
    <path d="M40 24 L58 32" />
    <path d="M40 40 L18 48" />
    <path d="M40 40 L62 48" />
    <path d="M40 56 L26 62" />
    <path d="M40 56 L54 62" />
  </svg>

  <svg
    class="cn-leaf cn-leaf--3"
    viewBox="0 0 56 88"
    width="38"
    height="60"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M28 4 C44 26 46 60 28 84 C12 60 14 26 28 4 Z" />
    <path d="M28 8 L28 80" />
    <path d="M28 24 L18 32" />
    <path d="M28 24 L38 32" />
    <path d="M28 42 L16 50" />
    <path d="M28 42 L40 50" />
    <path d="M28 58 L20 64" />
    <path d="M28 58 L36 64" />
  </svg>
</div>

<style lang="scss">
  .cn-leaves {
    position: absolute;
    inset: 0;
    // Sit above the page background but below text content.
    z-index: 0;
    pointer-events: none;
    overflow: hidden;

    // Cyber-only flourish: hidden by default, shown only in dark theme.
    display: none;
  }

  :global([data-theme='dark']) .cn-leaves {
    display: block;
  }

  @media (max-width: 768px) {
    .cn-leaves {
      display: none !important;
    }
  }

  .cn-leaf {
    position: absolute;
    opacity: 0;
    will-change: transform, opacity;
  }

  // Each leaf wears one of the three brand accents with a soft halo.
  .cn-leaf--1 {
    color: var(--accent-primary); // magenta
    filter: drop-shadow(0 0 6px var(--glow-primary-strong));
  }
  .cn-leaf--2 {
    color: var(--accent-secondary); // neon green
    filter: drop-shadow(0 0 6px var(--glow-secondary-strong));
  }
  .cn-leaf--3 {
    color: var(--accent-tertiary); // electric cyan
    filter: drop-shadow(0 0 6px rgba(0, 229, 255, 0.45));
  }

  // Leaf 1 (magenta) — drifts from upper-right inward, diagonal to mid-left
  .cn-leaf--1 {
    top: 4%;
    right: 6%;
    animation: cn-leaf-fall-1 10s var(--ease-out) 200ms forwards;
  }
  @keyframes cn-leaf-fall-1 {
    0%   { opacity: 0; transform: translate(0, -40px) rotate(-8deg); }
    8%   { opacity: 0.7; }
    60%  { opacity: 0.55; }
    100% { opacity: 0; transform: translate(-220px, 300px) rotate(78deg); }
  }

  // Leaf 2 (green) — slower, larger, gentler diagonal
  .cn-leaf--2 {
    top: 14%;
    right: 28%;
    animation: cn-leaf-fall-2 12s var(--ease-out) 1200ms forwards;
  }
  @keyframes cn-leaf-fall-2 {
    0%   { opacity: 0; transform: translate(0, -60px) rotate(12deg); }
    10%  { opacity: 0.65; }
    55%  { opacity: 0.5; transform: translate(80px, 180px) rotate(140deg); }
    100% { opacity: 0; transform: translate(180px, 340px) rotate(280deg); }
  }

  // Leaf 3 (cyan) — small, fast, off to the right
  .cn-leaf--3 {
    top: 2%;
    left: 42%;
    animation: cn-leaf-fall-3 9s var(--ease-out) 2400ms forwards;
  }
  @keyframes cn-leaf-fall-3 {
    0%   { opacity: 0; transform: translate(0, -50px) rotate(-20deg); }
    9%   { opacity: 0.65; }
    100% { opacity: 0; transform: translate(240px, 320px) rotate(220deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cn-leaves { display: none !important; }
  }
</style>
